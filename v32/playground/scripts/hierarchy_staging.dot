    L3 [label="topological algebra", fillcolor="#d0e0e3"];
    L4 [label="ring-theoretic props", fillcolor="#f4cccc"];
    L5 [label="algebraic hierarchy", fillcolor="#fff2cc"];
    L6 [label="notation / operations", fillcolor="#ffffff"];
    L1 -> L2 [style=invis];
    L2 -> L3 [style=invis];
    L3 -> L4 [style=invis];
    L4 -> L5 [style=invis];
    L5 -> L6 [style=invis];
  }
