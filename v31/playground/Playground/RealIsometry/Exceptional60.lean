def s5InvTable : Fin 60 → Fin 60 := ![0, 1, 2, 8, 4, 6, 5, 7, 3, 9, 10, 16, 12, 14, 13, 15, 11, 17, 20, 22, 18, 24, 19, 25, 21, 23, 30, 28, 27, 32, 26, 33, 29, 31, 34, 40, 36, 38, 37, 39, 35, 41, 44, 46, 42, 48, 43, 49, 45, 47, 52, 54, 50, 56, 51, 57, 53, 55, 58, 59]



def s5Mat (k : Fin 60) : MAT3 := (1/4 : ℝ) • mapZS5 (s5MatZ k)

/-! ### Verifications via native_decide -/

lemma s5MatZ_mul (i j : Fin 60) :
    s5MatZ i * s5MatZ j = (⟨4, 0⟩ : Zsqrtd 5) • s5MatZ (s5MulTable i j) := by
  fin_cases i <;> fin_cases j <;> native_decide

lemma s5MatZ_orth (k : Fin 60) :
    (s5MatZ k).transpose * s5MatZ k = (⟨16, 0⟩ : Zsqrtd 5) • 1 := by
  fin_cases k <;> native_decide

lemma s5MatZ_zero : s5MatZ 0 = (⟨4, 0⟩ : Zsqrtd 5) • 1 := by native_decide

lemma s5MatZ_order_le5 (i : Fin 60) :
    s5MatZ i ^ 2 = (⟨16, 0⟩ : Zsqrtd 5) • 1 ∨
    s5MatZ i ^ 3 = (⟨64, 0⟩ : Zsqrtd 5) • 1 ∨
    s5MatZ i ^ 5 = (⟨1024, 0⟩ : Zsqrtd 5) • 1 := by
  fin_cases i <;> simp <;> native_decide

lemma s5MatZ_injective : Function.Injective s5MatZ := by
  intro a b hab; apply mapZS5_injective; exact congrArg mapZS5 hab

lemma s5InvTable_mul (i : Fin 60) : s5MulTable (s5InvTable i) i = 0 := by
  fin_cases i <;> native_decide

/-! ### Transfer to real matrices -/

private lemma four_ne_zero : (4 : ℝ) ≠ 0 := by norm_num
private lemma quarter_ne_zero : (1/4 : ℝ) ≠ 0 := by norm_num

lemma s5Mat_mul (i j : Fin 60) : s5Mat i * s5Mat j = s5Mat (s5MulTable i j) := by
  unfold s5Mat
  rw [Matrix.smul_mul_assoc, Matrix.mul_smul_comm, ← mapZS5_mul, s5MatZ_mul, mapZS5_smul]
  simp [zsqrt5ToReal_int]; ring_nf; rfl

lemma s5Mat_one : s5Mat 0 = 1 := by
  unfold s5Mat; rw [s5MatZ_zero, mapZS5_smul, mapZS5_one]
  simp [zsqrt5ToReal_int]
  ext i j; simp [smul_apply, Algebra.id.smul_eq_mul]

lemma s5Mat_mem_O3 (k : Fin 60) : s5Mat k ∈ orthogonalGroup (Fin 3) ℝ := by
  rw [mem_orthogonalGroup_iff']
  unfold s5Mat
  rw [transpose_smul, Matrix.smul_mul_assoc, Matrix.mul_smul_comm,
      ← RingHom.mapMatrix_apply zsqrt5ToReal, ← RingHom.mapMatrix_apply zsqrt5ToReal,
      ← Matrix.map_transpose, ← mapZS5_mul, s5MatZ_orth, mapZS5_smul, mapZS5_one]
  simp [zsqrt5ToReal_int]
  ext i j; simp [smul_apply, Algebra.id.smul_eq_mul, one_apply]; split <;> ring

private lemma s5Mat_pow_eq (i : Fin 60) (n : ℕ) :
    s5Mat i ^ n = (1/4 : ℝ) ^ n • mapZS5 (s5MatZ i ^ n) := by
  induction n with
  | zero => simp [mapZS5_one, s5Mat]
  | succ n IH =>
    rw [pow_succ, IH, s5Mat, Matrix.smul_mul_assoc, Matrix.mul_smul_comm,
        ← mapZS5_mul, pow_succ, ← smul_smul]

lemma s5Mat_order_le5 (i : Fin 60) :
    s5Mat i ^ 2 = 1 ∨ s5Mat i ^ 3 = 1 ∨ s5Mat i ^ 5 = 1 := by
  rcases s5MatZ_order_le5 i with h | h | h
  · left; rw [s5Mat_pow_eq, h, mapZS5_smul, mapZS5_one, zsqrt5ToReal_int]
    ext i j; simp [smul_apply, Algebra.id.smul_eq_mul, one_apply]; split <;> ring
  · right; left; rw [s5Mat_pow_eq, h, mapZS5_smul, mapZS5_one, zsqrt5ToReal_int]
    ext i j; simp [smul_apply, Algebra.id.smul_eq_mul, one_apply]; split <;> ring
  · right; right; rw [s5Mat_pow_eq, h, mapZS5_smul, mapZS5_one, zsqrt5ToReal_int]
    ext i j; simp [smul_apply, Algebra.id.smul_eq_mul, one_apply]; split <;> ring

lemma s5Mat_injective : Function.Injective s5Mat := by
  intro a b hab
  apply s5MatZ_injective
  apply mapZS5_injective
  exact smul_right_injective _ quarter_ne_zero hab

/-! ### Constructing the SpaceIsometry subgroup -/

lemma multiplication_eq_hom' (A : O3) : multiplication A = multiplicationHom A := rfl

noncomputable def s5Elem (k : Fin 60) : SpaceIsometry :=
  multiplication ⟨s5Mat k, s5Mat_mem_O3 k⟩

lemma s5Elem_injective : Function.Injective s5Elem := by
  intro a b hab; apply s5Mat_injective
  exact congrArg Subtype.val (multiplicationHom_injective hab)

lemma s5Elem_mul (i j : Fin 60) : s5Elem i * s5Elem j = s5Elem (s5MulTable i j) := by
  simp only [s5Elem, multiplication_eq_hom', ← map_mul]
  congr 1; exact Subtype.ext (s5Mat_mul i j)

lemma s5Elem_one : s5Elem 0 = 1 := by
  simp only [s5Elem, multiplication_eq_hom']
  have h : (⟨s5Mat 0, s5Mat_mem_O3 0⟩ : O3) = 1 := Subtype.ext s5Mat_one
  rw [h]; exact map_one multiplicationHom

def icosahedralSubgroup : Subgroup SpaceIsometry where
  carrier := Set.range s5Elem
  mul_mem' := by
    rintro _ _ ⟨i, rfl⟩ ⟨j, rfl⟩
    exact ⟨s5MulTable i j, (s5Elem_mul i j).symm⟩
  one_mem' := ⟨0, s5Elem_one⟩
  inv_mem' := by
    rintro _ ⟨i, rfl⟩
    refine ⟨s5InvTable i, ?_⟩
    have hmul : s5Elem (s5InvTable i) * s5Elem i = 1 := by
      rw [s5Elem_mul, s5InvTable_mul, s5Elem_one]
    rw [eq_comm, inv_eq_of_mul_eq_one_left hmul]

/-! ### Cardinality -/

lemma card_icosahedralSubgroup : Nat.card icosahedralSubgroup = 60 := by
  change Nat.card (Set.range s5Elem) = 60
  simp [Nat.card_congr (Equiv.ofInjective s5Elem s5Elem_injective).symm]

/-! ### Exponent and element orders in the subgroup -/

lemma multiplication_pow (A : O3) (n : ℕ) : multiplication A ^ n = multiplication (A ^ n) := by
  simp only [multiplication_eq_hom', map_pow]

private lemma s5Elem_pow_n_eq_one {i : Fin 60} {n : ℕ} (h : s5Mat i ^ n = 1) :
    s5Elem i ^ n = 1 := by
  unfold s5Elem; rw [multiplication_pow]
  have : (⟨s5Mat i, s5Mat_mem_O3 i⟩ : O3) ^ n = 1 := Subtype.ext h
  rw [this]; exact multiplicationHom.map_one

private lemma forall_s5Elem (P : icosahedralSubgroup → Prop)
    (h : ∀ i : Fin 60, P ⟨s5Elem i, ⟨i, rfl⟩⟩) : ∀ g, P g := by
  intro g; obtain ⟨i, hi⟩ := g.prop
  have : g = ⟨s5Elem i, ⟨i, rfl⟩⟩ := Subtype.ext hi.symm
  rw [this]; exact h i

private lemma s5Elem_subgroup_pow_eq_one {i : Fin 60} {n : ℕ} (h : s5Mat i ^ n = 1) :
    (⟨s5Elem i, ⟨i, rfl⟩⟩ : icosahedralSubgroup) ^ n = 1 := by
  apply Subtype.ext; change (s5Elem i) ^ n = (1 : icosahedralSubgroup).val
  simp only [OneMemClass.coe_one]; exact s5Elem_pow_n_eq_one h

lemma icosahedralSubgroup_order_divides (g : icosahedralSubgroup) :
    g ^ 2 = 1 ∨ g ^ 3 = 1 ∨ g ^ 5 = 1 :=
  forall_s5Elem (fun g => g ^ 2 = 1 ∨ g ^ 3 = 1 ∨ g ^ 5 = 1) (fun i => by
    rcases s5Mat_order_le5 i with h | h | h
    · left; exact s5Elem_subgroup_pow_eq_one h
    · right; left; exact s5Elem_subgroup_pow_eq_one h
    · right; right; exact s5Elem_subgroup_pow_eq_one h) g

-- Exponent divides 30
lemma icosahedralSubgroup_pow_thirty (g : icosahedralSubgroup) : g ^ 30 = 1 := by
  rcases icosahedralSubgroup_order_divides g with h | h | h
  · have : g ^ (2 * 15) = 1 := by rw [pow_mul, h, one_pow]
    simpa using this
  · have : g ^ (3 * 10) = 1 := by rw [pow_mul, h, one_pow]
    simpa using this
  · have : g ^ (5 * 6) = 1 := by rw [pow_mul, h, one_pow]
    simpa using this

lemma icosahedralSubgroup_exponent_dvd_thirty :
    Monoid.exponent icosahedralSubgroup ∣ 30 :=
  Monoid.exponent_dvd_of_forall_pow_eq_one icosahedralSubgroup_pow_thirty

/-! ### Not cyclic -/

lemma icosahedralSubgroup_not_cyclic : ¬ IsCyclic icosahedralSubgroup := by
  intro hcyc
  have hexp := @IsCyclic.exponent_eq_card _ _ hcyc
  rw [card_icosahedralSubgroup] at hexp
  have h30 := icosahedralSubgroup_exponent_dvd_thirty
  rw [hexp] at h30; omega

/-! ### Not dihedral -/

lemma icosahedralSubgroup_no_order_thirty (g : icosahedralSubgroup) : orderOf g ≠ 30 := by
  intro h30
  rcases icosahedralSubgroup_order_divides g with h2 | h3 | h5
  · have := orderOf_dvd_of_pow_eq_one h2; rw [h30] at this; omega
  · have := orderOf_dvd_of_pow_eq_one h3; rw [h30] at this; omega
  · have := orderOf_dvd_of_pow_eq_one h5; rw [h30] at this; omega

lemma icosahedralSubgroup_not_dihedral : ¬ IsDihedral icosahedralSubgroup := by
  intro ⟨n, ⟨e⟩⟩
  have hcard : Nat.card (DihedralGroup n) = 60 := by
    rw [← card_icosahedralSubgroup, Nat.card_congr e.toEquiv]
  rw [DihedralGroup.nat_card] at hcard
  have hn : n = 30 := by omega
  subst hn
  have hr : orderOf (DihedralGroup.r (1 : ZMod 30)) = 30 := DihedralGroup.orderOf_r_one
  have := e.orderOf_eq (DihedralGroup.r 1)
  rw [hr] at this
  exact icosahedralSubgroup_no_order_thirty (e (DihedralGroup.r 1)) this

/-! ### Main result -/

lemma icosahedralSubgroup_isExceptional : IsExceptional icosahedralSubgroup :=
  ⟨icosahedralSubgroup_not_cyclic, icosahedralSubgroup_not_dihedral,
   by rw [card_icosahedralSubgroup]; omega⟩

theorem SpaceIsometry.existsExceptionalOfOrder60 (n : ℕ) [NeZero n]
    : ∃ f : Subgroup SpaceIsometry, IsExceptional f ∧ Nat.card f = 60 :=
  ⟨icosahedralSubgroup, icosahedralSubgroup_isExceptional, card_icosahedralSubgroup⟩
