open Matrix

abbrev IsDihedral (G : Type*) [Group G] : Prop := ∃ n : ℕ, Nonempty (DihedralGroup n ≃* G)

def IsExceptional (H : Subgroup SpaceIsometry) : Prop :=
  ¬ IsCyclic H ∧ ¬ IsDihedral H ∧ Nat.card H ≠ 0

/-! ## Icosahedral rotation group (A₅) as a subgroup of RealIsometry -/

/-! ### Ring homomorphism Zsqrtd 5 →+* ℝ -/

noncomputable def zsqrt5ToReal : Zsqrtd 5 →+* ℝ where
  toFun z := (z.re : ℝ) + (z.im : ℝ) * Real.sqrt 5
  map_one' := by simp [Zsqrtd.re_one, Zsqrtd.im_one]
  map_mul' a b := by
    show (↑(a * b).re : ℝ) + (↑(a * b).im : ℝ) * Real.sqrt 5 =
      ((↑a.re : ℝ) + (↑a.im : ℝ) * Real.sqrt 5) * ((↑b.re : ℝ) + (↑b.im : ℝ) * Real.sqrt 5)
    have h5 : Real.sqrt 5 ^ 2 = 5 := by
      rw [sq]; exact Real.mul_self_sqrt (by norm_num)
    simp only [Zsqrtd.re_mul, Zsqrtd.im_mul]; push_cast; ring_nf; rw [h5]
  map_zero' := by simp [Zsqrtd.re_zero, Zsqrtd.im_zero]
  map_add' a b := by simp only [Zsqrtd.re_add, Zsqrtd.im_add, Int.cast_add]; ring

lemma zsqrt5ToReal_int (n : ℤ) : zsqrt5ToReal ⟨n, 0⟩ = (n : ℝ) := by simp [zsqrt5ToReal]

/-! ### Matrix map infrastructure -/

noncomputable abbrev mapZS5 := RingHom.mapMatrix (n := Fin 3) zsqrt5ToReal

lemma mapZS5_mul (A B : Matrix (Fin 3) (Fin 3) (Zsqrtd 5)) :
    mapZS5 (A * B) = mapZS5 A * mapZS5 B := mapZS5.map_mul A B

lemma mapZS5_one : mapZS5 1 = (1 : MAT3) := mapZS5.map_one

lemma mapZS5_smul (c : Zsqrtd 5) (M : Matrix (Fin 3) (Fin 3) (Zsqrtd 5)) :
    mapZS5 (c • M) = zsqrt5ToReal c • mapZS5 M := by
  ext i j; simp [RingHom.mapMatrix_apply, map_apply, Algebra.id.smul_eq_mul, map_mul]

lemma mapZS5_injective : Function.Injective mapZS5 := by
  intro A B h
  ext i j
  have := congr_fun₂ h i j
  simp [RingHom.mapMatrix_apply, map_apply] at this
  have hinj : Function.Injective zsqrt5ToReal := by
    intro a b hab
    have h_re : (a.re : ℝ) + (a.im : ℝ) * Real.sqrt 5 = (b.re : ℝ) + (b.im : ℝ) * Real.sqrt 5 := by
      change zsqrt5ToReal a = zsqrt5ToReal b at hab; exact hab
    by_cases him : a.im = b.im
    · have : (a.re : ℝ) = (b.re : ℝ) := by linarith
      exact Zsqrtd.ext (Int.cast_injective this) him
    · exfalso
      have : Real.sqrt 5 = ((b.re : ℝ) - a.re) / ((a.im : ℝ) - b.im) := by
        have : ((a.im : ℝ) - b.im) * Real.sqrt 5 = (b.re : ℝ) - a.re := by linarith
        field_simp at this ⊢; linarith
      have hirr : Irrational (Real.sqrt 5) :=
        irrational_sqrt_natCast_iff.mpr (by decide)
      exact hirr.ne_rat _ (by rw [this]; push_cast; ring_nf; rfl)
  exact hinj this

