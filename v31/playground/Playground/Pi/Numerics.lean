/-- Rational lower bound for `x := π·√163`: `x_lo < π·√163`. -/
private theorem x_lo_lt : (200545849955662598776750418114520700269/5000000000000000000000000000000000000 : ℝ) < π * Real.sqrt 163 := by
  have h : (314159265358979323846264338327950288419/100000000000000000000000000000000000000 : ℝ) * (638357266740185233085547600489044617369/50000000000000000000000000000000000000 : ℝ) < π * Real.sqrt 163 :=
    mul_lt_mul'' pi_gt_d38 sqrt_163_gt_d38 (by norm_num) (by norm_num)
  refine lt_of_le_of_lt ?_ h
  norm_num

/-- Rational upper bound for `x := π·√163`: `π·√163 < x_hi`. -/
private theorem lt_x_hi : π * Real.sqrt 163 < (4010916999113251975535008362290414005397/100000000000000000000000000000000000000 : ℝ) := by
  have h : π * Real.sqrt 163 < (15707963267948966192313216916397514421/5000000000000000000000000000000000000 : ℝ) * (1276714533480370466171095200978089234739/100000000000000000000000000000000000000 : ℝ) :=
    mul_lt_mul'' pi_lt_d38 sqrt_163_lt_d38 Real.pi_pos.le (Real.sqrt_nonneg 163)
  refine lt_of_lt_of_le h ?_
  norm_num

/-- Upper bound for `exp(x_hi/128)` from the degree-26 Taylor remainder. -/
private theorem exp_b_le : Real.exp (4010916999113251975535008362290414005397/12800000000000000000000000000000000000000 : ℝ) ≤ (684002100810295204481646340962993278268002661/500000000000000000000000000000000000000000000 : ℝ) := by
  have hb := Real.exp_bound' (x := (4010916999113251975535008362290414005397/12800000000000000000000000000000000000000 : ℝ)) (by norm_num) (by norm_num) (n := 26)
    (by norm_num)
  refine hb.trans ?_
  norm_num [Finset.sum_range_succ, Nat.factorial]

/-- Lower bound for `exp(x_lo/128)` from the degree-26 Taylor partial sum. -/
private theorem le_exp_a : (1710005252025738011204115852407483195667481713/1250000000000000000000000000000000000000000000 : ℝ) ≤ Real.exp (200545849955662598776750418114520700269/640000000000000000000000000000000000000 : ℝ) := by
  refine le_trans ?_ (Real.sum_le_exp_of_nonneg (by norm_num) 26)
  norm_num [Finset.sum_range_succ, Nat.factorial]

/-- `exp(π·√163) < (exp(x_hi/128))^128`-bound. -/
private theorem exp_pi_sqrt_163_lt_Ubig :
    Real.exp (π * Real.sqrt 163) < (684002100810295204481646340962993278268002661/500000000000000000000000000000000000000000000 : ℝ) ^ 128 := by
  have hmono : Real.exp (π * Real.sqrt 163) < Real.exp (4010916999113251975535008362290414005397/100000000000000000000000000000000000000 : ℝ) :=
    Real.exp_lt_exp.mpr lt_x_hi
  refine hmono.trans_le ?_
  have e : Real.exp (4010916999113251975535008362290414005397/100000000000000000000000000000000000000 : ℝ) = Real.exp (4010916999113251975535008362290414005397/12800000000000000000000000000000000000000 : ℝ) ^ 128 := by
    rw [show (4010916999113251975535008362290414005397/100000000000000000000000000000000000000 : ℝ) = (128 : ℕ) * (4010916999113251975535008362290414005397/12800000000000000000000000000000000000000 : ℝ) by push_cast; norm_num, Real.exp_nat_mul]
  rw [e]
  exact pow_le_pow_left₀ (Real.exp_nonneg _) exp_b_le 128

/-- `(exp(x_lo/128))^128 < exp(π·√163)`-bound. -/
private theorem Lbig_lt_exp_pi_sqrt_163 :
    (1710005252025738011204115852407483195667481713/1250000000000000000000000000000000000000000000 : ℝ) ^ 128 < Real.exp (π * Real.sqrt 163) := by
  have hmono : Real.exp (200545849955662598776750418114520700269/5000000000000000000000000000000000000 : ℝ) < Real.exp (π * Real.sqrt 163) :=
    Real.exp_lt_exp.mpr x_lo_lt
  refine lt_of_le_of_lt ?_ hmono
  have e : Real.exp (200545849955662598776750418114520700269/5000000000000000000000000000000000000 : ℝ) = Real.exp (200545849955662598776750418114520700269/640000000000000000000000000000000000000 : ℝ) ^ 128 := by
    rw [show (200545849955662598776750418114520700269/5000000000000000000000000000000000000 : ℝ) = (128 : ℕ) * (200545849955662598776750418114520700269/640000000000000000000000000000000000000 : ℝ) by push_cast; norm_num, Real.exp_nat_mul]
  rw [e]
  exact pow_le_pow_left₀ (by norm_num) le_exp_a 128

/-! ### Bounds for `e^{-π√163}`

`e^{-π√163} = 3.808980937007652338226231516478005437619629319381…e-18`
(30 significant digits certified below). This is `‖q τ₁₆₃‖`, the quantity all
the truncation-error estimates of ch. 5/10 are evaluated at. -/

/-- Lower bound for `e^{-π√163}` (30 significant digits), i.e.
`380898093700765233822623151647 / 10^47 < e^{-π√163}`.
To be proved by ℚ-interval arithmetic + `Real.exp_bound` (PLAN D1). -/
theorem exp_neg_pi_sqrt_163_gt :
    3.80898093700765233822623151647e-18 < Real.exp (-(π * Real.sqrt 163)) := by
  rw [Real.exp_neg]
  have hE : Real.exp (π * Real.sqrt 163) < (684002100810295204481646340962993278268002661/500000000000000000000000000000000000000000000 : ℝ) ^ 128 := exp_pi_sqrt_163_lt_Ubig
  have hUpos : (0 : ℝ) < (684002100810295204481646340962993278268002661/500000000000000000000000000000000000000000000 : ℝ) ^ 128 := by positivity
  have hEpos : (0 : ℝ) < Real.exp (π * Real.sqrt 163) := Real.exp_pos _
  calc (3.80898093700765233822623151647e-18 : ℝ)
      ≤ ((684002100810295204481646340962993278268002661/500000000000000000000000000000000000000000000 : ℝ) ^ 128)⁻¹ := by
        rw [← one_div, le_div_iff₀ hUpos]; norm_num
    _ < (Real.exp (π * Real.sqrt 163))⁻¹ := by
        exact (inv_lt_inv₀ hUpos hEpos).mpr hE

/-- Upper bound for `e^{-π√163}` (30 significant digits), i.e.
`e^{-π√163} < 380898093700765233822623151648 / 10^47`.
To be proved by ℚ-interval arithmetic + `Real.exp_bound` (PLAN D1). -/
theorem exp_neg_pi_sqrt_163_lt :
    Real.exp (-(π * Real.sqrt 163)) < 3.80898093700765233822623151648e-18 := by
  rw [Real.exp_neg]
  have hE : (1710005252025738011204115852407483195667481713/1250000000000000000000000000000000000000000000 : ℝ) ^ 128 < Real.exp (π * Real.sqrt 163) := Lbig_lt_exp_pi_sqrt_163
  have hLpos : (0 : ℝ) < (1710005252025738011204115852407483195667481713/1250000000000000000000000000000000000000000000 : ℝ) ^ 128 := by positivity
  have hEpos : (0 : ℝ) < Real.exp (π * Real.sqrt 163) := Real.exp_pos _
  calc (Real.exp (π * Real.sqrt 163))⁻¹
      < ((1710005252025738011204115852407483195667481713/1250000000000000000000000000000000000000000000 : ℝ) ^ 128)⁻¹ := (inv_lt_inv₀ hEpos hLpos).mpr hE
    _ ≤ (3.80898093700765233822623151648e-18 : ℝ) := by
        rw [← one_div, div_le_iff₀ hLpos]; norm_num

/-! ### The nome at `τ₁₆₃` -/

/-- The magnitude of the nome at the CM point: `‖q τ₁₆₃‖ = e^{-π√163}`. -/
theorem norm_q_τ₁₆₃ : ‖q τ₁₆₃‖ = Real.exp (-(π * Real.sqrt 163)) := by
  rw [norm_q, τ₁₆₃_im]
  congr 1
  ring

/-- The nome at the CM point is real and *negative*:
`q τ₁₆₃ = e^{2πi(1/2 + i√163/2)} = e^{πi}·e^{-π√163} = -e^{-π√163}`. -/
theorem q_τ₁₆₃_eq : q τ₁₆₃ = -Complex.exp (-(π * Real.sqrt 163) : ℝ) := by
  rw [q_eq]
  have hre : τ₁₆₃.re = 1 / 2 := rfl
  have hτ : (τ₁₆₃ : ℂ) = ((1 / 2 : ℝ) : ℂ) + ((Real.sqrt 163 / 2 : ℝ) : ℂ) * Complex.I := by
    apply Complex.ext <;> simp [hre]
  have harg : 2 * (π : ℂ) * Complex.I * (τ₁₆₃ : ℂ)
      = ((-(π * Real.sqrt 163) : ℝ) : ℂ) + π * Complex.I := by
    rw [hτ]
    push_cast
    linear_combination ((π : ℂ) * (Real.sqrt 163 : ℂ)) * Complex.I_sq
  rw [harg, Complex.exp_add, Complex.exp_pi_mul_I]
  ring

/-- Restatement of `q_τ₁₆₃_eq` via the real exponential: `q τ₁₆₃` is the coercion of
the negative real number `-e^{-π√163}`. -/
theorem q_τ₁₆₃_eq_ofReal :
    q τ₁₆₃ = ((-Real.exp (-(π * Real.sqrt 163)) : ℝ) : ℂ) := by
  rw [q_τ₁₆₃_eq]
  push_cast [Complex.ofReal_exp]
  ring

end Chudnovsky
